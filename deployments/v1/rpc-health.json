{
  "schemaVersion": "1.0.0",
  "description": "Ops health probe configuration for Stellar Horizon and Soroban RPC endpoints.",
  "networks": {
    "testnet": {
      "horizon": {
        "primary": "https://horizon-testnet.stellar.org",
        "fallbacks": [
          "https://horizon-testnet.stellar.lobstr.co"
        ]
      },
      "rpc": {
        "primary": "https://soroban-testnet.stellar.org",
        "fallbacks": [
          "https://rpc-futurenet.stellar.org"
        ]
      }
    },
    "mainnet": {
      "horizon": {
        "primary": "https://horizon.stellar.org",
        "fallbacks": [
          "https://horizon.stellar.lobstr.co"
        ]
      },
      "rpc": {
        "primary": "https://mainnet.sorobanrpc.com",
        "fallbacks": [
          "https://soroban-rpc.mainnet.stellar.gateway.fm"
        ]
      }
    }
  },
  "thresholds": {
    "timeoutMs": 10000,
    "warnLatencyMs": 2500,
    "maxErrorRate": 0
  },
  "alerting": {
    "webhookEnv": "OPS_ALERT_WEBHOOK_URL",
    "payloadFormat": "json",
    "failureLogLevel": "error"
  }
}
